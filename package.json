{
  "name": "meem8",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3008",
    "build": "next build",
    "build:cloudflare": "mv src/app/api /tmp/meem8-api; STATIC_EXPORT=true next build; STATUS=$?; mv /tmp/meem8-api src/app/api; exit $STATUS",
    "deploy:cloudflare": "npm run build:cloudflare && npx wrangler deploy",
    "start": "next start -p 3008",
    "lint": "eslint",
    "tunnel": "npx ngrok http 3008"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hnswlib-node": "^3.0.0",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.3",
    "next": "16.2.6",
    "ollama": "^0.6.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
